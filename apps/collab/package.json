{
  "name": "prdmaker-collab",
  "version": "0.1.0",
  "private": true,
  "description": "Hocuspocus collaboration server for PRDMaker (Yjs persistence + JWT auth)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hocuspocus/extension-database": "^2.13.7",
    "@hocuspocus/server": "^2.13.7",
    "dotenv": "^16.4.7",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "yjs": "^13.6.20"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

# Hocuspocus collab server config

# Postgres — must point at the same DB as the Next.js app so we can read/write
# the Page.yDocState column.
DATABASE_URL="postgresql://user:password@host:5432/prdmaker?schema=public"

# Shared secret with Next.js. Used to verify JWTs minted by /api/collab/token.
# openssl rand -hex 32
COLLAB_SECRET=""

# Port the Hocuspocus WebSocket listens on.
PORT=1234

// PRDMaker — initial schema
// Auth.js v5 (Prisma adapter) shape + workspace tenancy.
// Subsequent migrations (Step 7+) extend this with pages, comments,
// versions, templates, AI threads, billing, audit, etc.

generator client {
  provider      = "prisma-client-js"
  // "native" covers local dev and the Docker (alpine/musl) build; the explicit
  // rhel target is the query-engine binary Vercel / AWS Lambda load at runtime.
  // Without it a Vercel build can ship a client that can't find its engine.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth.js models ----------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Optional bring-your-own Anthropic key (Step 19). Encrypted at rest with
  // AES-256-GCM (see src/lib/crypto.ts); the plaintext key is never stored or
  // returned after save. `anthropicKeyLast4` is the only non-secret hint shown
  // back in the UI ("•••• last4").
  anthropicKeyCipher String?
  anthropicKeyIv     String?
  anthropicKeyTag    String?
  anthropicKeyLast4  String?

  accounts               Account[]
  sessions               Session[]
  workspaceMembers       WorkspaceMember[]
  invitesCreated         WorkspaceInvite[]       @relation("InviteCreatedBy")
  pagesCreated           Page[]                  @relation("PageCreatedBy")
  pageVersions           PageVersion[]
  comments               Comment[]
  pagePermissions        PagePermission[]
  assignedPages          Page[]                  @relation("PageAssignee")
  epicsCreated           Epic[]                  @relation("EpicCreatedBy")
  notifications          Notification[]
  notificationPreference NotificationPreference?
  aiThreads              AiThread[]
  agentThreads           AgentThread[]
  featuresCreated        Feature[]               @relation("FeatureCreatedBy")
  impactAnalyses         ImpactAnalysis[]        @relation("ImpactAnalysisCreatedBy")
  agentJobsRequested     AgentJob[]              @relation("AgentJobRequestedBy")
  guideChecksCreated     GuideCheck[]            @relation("GuideCheckCreatedBy")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Tenancy ----------

enum Role {
  OWNER
  // Elevated editor that owns the application's feature catalog — the gate
  // for bulk feature import (development_plan.md Step 56). Ranked between
  // EDITOR and OWNER in src/lib/config.ts ROLE_RANK.
  DEV_LEAD
  EDITOR
  VIEWER
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members        WorkspaceMember[]
  invites        WorkspaceInvite[]
  pages          Page[]
  templates      Template[]
  epics          Epic[]
  aiUsage        AiUsage[]
  stacks         Stack[]
  features       Feature[]
  featureLinks   FeatureLink[]
  impactAnalyses ImpactAnalysis[]
  agentJobs      AgentJob[]
  agentThreads   AgentThread[]
  guideChecks    GuideCheck[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        Role     @default(EDITOR)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model WorkspaceInvite {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  role        Role      @default(EDITOR)
  token       String    @unique
  createdById String
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  acceptedAt  DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
}

// ---------- Pages, versions, comments, templates ----------

model Page {
  id          String    @id @default(cuid())
  workspaceId String
  parentId    String?
  title       String    @default("Untitled")
  /// Fractional ordering — see src/lib/positions.ts.
  position    Float     @default(0)
  /// Authoritative TipTap/Yjs content as JSON. Yjs binary state lives in
  /// `yDocState` once Hocuspocus ships (Step 12).
  contentJson Json?
  /// Plain-text projection of contentJson — kept in sync on every write so
  /// search (Step 22) can index without parsing JSON.
  contentText String    @default("")
  /// Yjs CRDT snapshot. Persisted by Hocuspocus on idle/disconnect (Step 12).
  yDocState   Bytes?
  isPublished Boolean   @default(false)
  publicSlug  String?   @unique
  /// Template this page was created from (Step 57) — the completeness
  /// checklist's target. Null for blank pages and pages predating the field;
  /// SetNull on template delete (pages never depend on a template's fate).
  templateId  String?
  createdById String
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Agile / epic metadata (Step 40)
  epicId       String?
  agileStatus  AgileStatus @default(BACKLOG)
  priority     Priority?
  storyPoints  Int?
  targetSprint String?
  assigneeId   String?
  externalUrl  String?

  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent         Page?            @relation("PageChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children       Page[]           @relation("PageChildren")
  createdBy      User             @relation("PageCreatedBy", fields: [createdById], references: [id])
  epic           Epic?            @relation(fields: [epicId], references: [id], onDelete: SetNull)
  assignee       User?            @relation("PageAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  template       Template?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  versions       PageVersion[]
  comments       Comment[]
  permissions    PagePermission[]
  aiThreads      AiThread[]
  featureLinks   PageFeature[]
  impactAnalyses ImpactAnalysis[]
  guideCheck     GuideCheck?

  @@index([workspaceId, parentId])
  @@index([workspaceId, archivedAt])
  @@index([parentId, position])
  @@index([workspaceId, epicId])
  @@index([templateId])
}

enum VersionKind {
  AUTO
  MANUAL
  PRE_AI
}

model PageVersion {
  id           String      @id @default(cuid())
  pageId       String
  /// JSON projection of the editor doc — used for diff rendering (Step 16).
  snapshotJson Json
  /// Optional Yjs binary state for exact restore.
  yDocState    Bytes?
  kind         VersionKind @default(AUTO)
  createdById  String
  createdAt    DateTime    @default(now())

  page      Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdById], references: [id])

  @@index([pageId, createdAt])
}

model Comment {
  id         String    @id @default(cuid())
  pageId     String
  parentId   String?
  authorId   String
  body       String
  /// Anchor in the editor doc — `{from: number, to: number}` from
  /// ProseMirror, or null for page-level comments.
  anchor     Json?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  page    Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")
  author  User      @relation(fields: [authorId], references: [id])

  @@index([pageId])
  @@index([parentId])
}

model Template {
  id          String   @id @default(cuid())
  /// Null means a system template seeded for every workspace.
  workspaceId String?
  name        String
  description String?
  contentJson Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pages     Page[]

  @@index([workspaceId])
}

model PagePermission {
  id     String @id @default(cuid())
  pageId String
  userId String
  role   Role

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pageId, userId])
  @@index([pageId])
  @@index([userId])
}

// ---------- Agile / Epics ----------

enum EpicStatus {
  PLANNED
  IN_PROGRESS
  DONE
}

enum AgileStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Epic {
  id          String     @id @default(cuid())
  workspaceId String
  /// Human-facing label, assigned on create as `EPIC-<n>` (Step 41).
  key         String
  name        String     @default("Untitled epic")
  description String?
  status      EpicStatus @default(PLANNED)
  /// Hex color for the epic chip + board card accent.
  color       String     @default("#5333D8")
  /// Fractional ordering within a board column — see src/lib/pages.ts.
  position    Float      @default(0)
  createdById String
  archivedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("EpicCreatedBy", fields: [createdById], references: [id])
  pages     Page[]

  @@unique([workspaceId, key])
  @@index([workspaceId, status])
}

// ---------- Notifications ----------

model Notification {
  id        String    @id @default(cuid())
  userId    String
  /// NotificationType string — see src/lib/notifications.ts.
  type      String
  /// Denormalized render data (actor name, page title/slug, url, …).
  payload   Json
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model NotificationPreference {
  id           String   @id @default(cuid())
  userId       String   @unique
  /// Per-type email delivery toggles. The in-app inbox always receives.
  emailMention Boolean  @default(true)
  emailReply   Boolean  @default(true)
  emailShare   Boolean  @default(true)
  emailInvite  Boolean  @default(true)
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------- AI usage / quotas ----------

/// One row per workspace per calendar-month, metering managed-tier AI usage
/// (Step 19). BYO-key requests bypass the managed cap and are not metered
/// here. `period` is the UTC "YYYY-MM" bucket; see src/lib/ai-usage.ts.
model AiUsage {
  id           String   @id @default(cuid())
  workspaceId  String
  period       String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  requestCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, period])
  @@index([workspaceId])
}

/// Per-user, per-page AI chat thread (Step 20). One conversation each member
/// keeps about a given PRD; messages persist so the thread survives reloads.
model AiThread {
  id        String   @id @default(cuid())
  pageId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  page     Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  @@unique([pageId, userId])
  @@index([pageId])
}

model AiMessage {
  id        String   @id @default(cuid())
  threadId  String
  /// "user" | "assistant" — maps directly to Anthropic message roles.
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  thread AiThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

// ---------- Workspace agent — feature graph (ai_development_plan.md Step 44) ----------
//
// One workspace = one application. Stacks are its deployable surfaces;
// features are graph nodes owned by a stack; FeatureLink rows are typed
// cross-stack edges; PageFeature ties PRDs to the features they define,
// modify (= change request), or reference. The agent only ever writes rows
// with status SUGGESTED — the review queue (Step 50) promotes them.

/// Deployable surface of the application (Step 45 seeds Frontend, Backend,
/// API, WebSocket, Email UI by default).
enum StackType {
  FRONTEND
  BACKEND
  API
  WEBSOCKET
  EMAIL
  MOBILE
  INFRA
  OTHER
}

enum FeatureStatus {
  SUGGESTED
  ACTIVE
  DEPRECATED
}

/// Provenance of a graph row — agent-written (extraction, chat tools) or
/// human-written. Status, not origin, is what gates canonical reads.
enum AgentOrigin {
  AGENT
  MANUAL
}

/// Directed edge semantics between features. See src/lib/agent/types.ts for
/// labels + one-line descriptions used in pickers and agent prompts.
enum FeatureLinkKind {
  DEPENDS_ON
  CONSUMES
  TRIGGERS
  EXTENDS
  IMPACTS
  RELATES_TO
}

/// Review lifecycle of agent-proposed rows. The agent only writes SUGGESTED;
/// the Step 50 queue promotes to CONFIRMED or parks as REJECTED (kept so the
/// same suggestion isn't re-proposed by a later extraction run).
enum SuggestionStatus {
  SUGGESTED
  CONFIRMED
  REJECTED
}

/// How a PRD relates to a feature. MODIFIES marks a change request (CR).
enum PageFeatureRole {
  DEFINES
  MODIFIES
  REFERENCES
}

enum ImpactRunStatus {
  RUNNING
  READY
  FAILED
}

enum AgentJobType {
  SCAN_WORKSPACE
  EXTRACT_PAGE
}

enum AgentJobStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

/// A deployable surface of the workspace's application (BE, API, WS, FE,
/// Email UI, …). Features belong to exactly one stack; links wire features
/// across stacks. Managed in settings (Step 45).
model Stack {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  type        StackType @default(OTHER)
  description String?
  /// Hex accent for the stack's features in lists and the mind map.
  color       String    @default("#5333D8")
  /// Fractional ordering — same approach as the page tree.
  position    Float     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  features  Feature[]

  @@unique([workspaceId, name])
  @@index([workspaceId, position])
}

/// Node of the workspace feature mind map. Fail-closed defaults: agent
/// writes are born SUGGESTED/AGENT; manual code paths (Step 46) explicitly
/// set ACTIVE/MANUAL. `summary` is the unit of context the model reads in
/// the workspace catalog — keep it to one or two crisp sentences.
model Feature {
  id          String        @id @default(cuid())
  workspaceId String
  stackId     String
  name        String
  summary     String        @db.Text
  status      FeatureStatus @default(SUGGESTED)
  origin      AgentOrigin   @default(AGENT)
  /// Null for agent-created rows.
  createdById String?
  archivedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  /// NoAction (not Restrict): Postgres still blocks deleting a stack that has
  /// features (Step 45 prompts to reassign first), but the check defers to
  /// statement end so workspace-cascade deletes don't trip over it.
  stack     Stack     @relation(fields: [stackId], references: [id], onDelete: NoAction)
  createdBy User?     @relation("FeatureCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  linksFrom FeatureLink[] @relation("FeatureLinkFrom")
  linksTo   FeatureLink[] @relation("FeatureLinkTo")
  pageLinks PageFeature[]

  @@index([workspaceId, stackId])
  @@index([workspaceId, status])
}

/// Directed, typed edge of the mind map (from → to), usually cross-stack:
/// an FE "Sign-up form" CONSUMES an API "Register endpoint" which TRIGGERS
/// an Email "Welcome mail". `kind` has no default — edge semantics must be
/// stated explicitly by every writer.
model FeatureLink {
  id            String           @id @default(cuid())
  workspaceId   String
  fromFeatureId String
  toFeatureId   String
  kind          FeatureLinkKind
  status        SuggestionStatus @default(SUGGESTED)
  origin        AgentOrigin      @default(AGENT)
  /// Agent's 0–1 confidence on SUGGESTED rows; null on manual rows.
  confidence    Float?
  /// Why the agent thinks this edge exists — shown in the review queue.
  rationale     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  fromFeature Feature   @relation("FeatureLinkFrom", fields: [fromFeatureId], references: [id], onDelete: Cascade)
  toFeature   Feature   @relation("FeatureLinkTo", fields: [toFeatureId], references: [id], onDelete: Cascade)

  @@unique([fromFeatureId, toFeatureId, kind])
  @@index([workspaceId, status])
  @@index([toFeatureId])
}

/// Joins a PRD to a feature it DEFINES, MODIFIES (= change request), or
/// REFERENCES. Tenancy derives through page/feature — both carry the same
/// workspaceId by construction (enforced in the service layer).
model PageFeature {
  id        String           @id @default(cuid())
  pageId    String
  featureId String
  role      PageFeatureRole
  status    SuggestionStatus @default(SUGGESTED)
  origin    AgentOrigin      @default(AGENT)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  page    Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([pageId, featureId, role])
  @@index([featureId])
}

/// One impact-analysis run for a PRD (Step 52). A RUNNING row is written
/// before the model call so failures persist as FAILED + error. `report`
/// follows the ImpactReport contract in src/lib/agent/types.ts.
model ImpactAnalysis {
  id          String          @id @default(cuid())
  workspaceId String
  pageId      String
  status      ImpactRunStatus @default(RUNNING)
  report      Json?
  /// Model id that produced the report (BYO Sonnet vs managed Haiku).
  model       String?
  error       String?
  createdById String
  createdAt   DateTime        @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  page      Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdBy User      @relation("ImpactAnalysisCreatedBy", fields: [createdById], references: [id])

  @@index([pageId, createdAt])
  @@index([workspaceId])
}

/// Per-user, workspace-scope agent chat thread (Step 48) — deliberately
/// separate from the per-page AiThread so Step 20 page chat stays untouched.
model AgentThread {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AgentMessage[]

  @@unique([workspaceId, userId])
  @@index([userId])
}

model AgentMessage {
  id        String   @id @default(cuid())
  threadId  String
  /// "user" | "assistant" — maps directly to Anthropic message roles.
  role      String
  content   String   @db.Text
  /// Tool-call trace for transparency — [{name, ok, input, result}], all
  /// strings truncated at write time. Null on user turns / tool-less replies.
  toolUse   Json?
  createdAt DateTime @default(now())

  thread AgentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

/// DB-backed queue for background agent work, drained by the agent-sync cron
/// (Step 49) — same infra-free pattern as snapshot-dirty. `pageId` is a plain
/// column (no FK): a job whose page has vanished is skipped and marked DONE.
/// QUEUED-dedupe on [workspaceId, type, pageId] lives in service code —
/// Prisma doesn't model partial uniques.
model AgentJob {
  id            String         @id @default(cuid())
  workspaceId   String
  type          AgentJobType
  pageId        String?
  status        AgentJobStatus @default(QUEUED)
  attempts      Int            @default(0)
  error         String?
  /// Null when enqueued by the system (publish/snapshot hooks, cron fan-out).
  requestedById String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requestedBy User?     @relation("AgentJobRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([workspaceId, type, pageId])
}

// ---------- PRD guide — completeness checklist (development_plan.md Step 57) ----------
//
// The AI-judged completeness rail: a page's checklist target comes from its
// source template's headings (fallback: the doc's own outline), and GuideCheck
// stores the latest evaluation — one row per page, upserted per run. Current
// state, not history (unlike ImpactAnalysis).

/// Lifecycle of a completeness check run — mirrors ImpactRunStatus semantics.
enum GuideCheckStatus {
  RUNNING
  READY
  FAILED
}

/// Latest completeness check for a page. `report` follows the
/// GuideCheckReport contract in src/lib/guide/types.ts and is only
/// overwritten on READY, so a FAILED run keeps the last good report.
model GuideCheck {
  id          String           @id @default(cuid())
  workspaceId String
  pageId      String           @unique
  status      GuideCheckStatus @default(RUNNING)
  report      Json?
  /// Model id that produced the report (BYO Sonnet vs managed Haiku).
  /// Nullable so FAILED rows persist even when client resolution fails.
  model       String?
  error       String?
  createdById String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  page      Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdBy User      @relation("GuideCheckCreatedBy", fields: [createdById], references: [id])

  @@index([workspaceId])
}

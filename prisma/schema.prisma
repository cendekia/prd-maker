// PRDMaker — initial schema
// Auth.js v5 (Prisma adapter) shape + workspace tenancy.
// Subsequent migrations (Step 7+) extend this with pages, comments,
// versions, templates, AI threads, billing, audit, etc.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth.js models ----------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Optional bring-your-own Anthropic key (Step 19). Encrypted at rest with
  // AES-256-GCM (see src/lib/crypto.ts); the plaintext key is never stored or
  // returned after save. `anthropicKeyLast4` is the only non-secret hint shown
  // back in the UI ("•••• last4").
  anthropicKeyCipher String?
  anthropicKeyIv     String?
  anthropicKeyTag    String?
  anthropicKeyLast4  String?

  accounts               Account[]
  sessions               Session[]
  workspaceMembers       WorkspaceMember[]
  invitesCreated         WorkspaceInvite[]       @relation("InviteCreatedBy")
  pagesCreated           Page[]                  @relation("PageCreatedBy")
  pageVersions           PageVersion[]
  comments               Comment[]
  pagePermissions        PagePermission[]
  assignedPages          Page[]                  @relation("PageAssignee")
  epicsCreated           Epic[]                  @relation("EpicCreatedBy")
  notifications          Notification[]
  notificationPreference NotificationPreference?
  aiThreads              AiThread[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Tenancy ----------

enum Role {
  OWNER
  EDITOR
  VIEWER
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   WorkspaceMember[]
  invites   WorkspaceInvite[]
  pages     Page[]
  templates Template[]
  epics     Epic[]
  aiUsage   AiUsage[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        Role     @default(EDITOR)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model WorkspaceInvite {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  role        Role      @default(EDITOR)
  token       String    @unique
  createdById String
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  acceptedAt  DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
}

// ---------- Pages, versions, comments, templates ----------

model Page {
  id          String    @id @default(cuid())
  workspaceId String
  parentId    String?
  title       String    @default("Untitled")
  /// Fractional ordering — see src/lib/positions.ts.
  position    Float     @default(0)
  /// Authoritative TipTap/Yjs content as JSON. Yjs binary state lives in
  /// `yDocState` once Hocuspocus ships (Step 12).
  contentJson Json?
  /// Plain-text projection of contentJson — kept in sync on every write so
  /// search (Step 22) can index without parsing JSON.
  contentText String    @default("")
  /// Yjs CRDT snapshot. Persisted by Hocuspocus on idle/disconnect (Step 12).
  yDocState   Bytes?
  isPublished Boolean   @default(false)
  publicSlug  String?   @unique
  createdById String
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Agile / epic metadata (Step 40)
  epicId       String?
  agileStatus  AgileStatus @default(BACKLOG)
  priority     Priority?
  storyPoints  Int?
  targetSprint String?
  assigneeId   String?
  externalUrl  String?

  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent      Page?            @relation("PageChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children    Page[]           @relation("PageChildren")
  createdBy   User             @relation("PageCreatedBy", fields: [createdById], references: [id])
  epic        Epic?            @relation(fields: [epicId], references: [id], onDelete: SetNull)
  assignee    User?            @relation("PageAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  versions    PageVersion[]
  comments    Comment[]
  permissions PagePermission[]
  aiThreads   AiThread[]

  @@index([workspaceId, parentId])
  @@index([workspaceId, archivedAt])
  @@index([parentId, position])
  @@index([workspaceId, epicId])
}

enum VersionKind {
  AUTO
  MANUAL
  PRE_AI
}

model PageVersion {
  id           String      @id @default(cuid())
  pageId       String
  /// JSON projection of the editor doc — used for diff rendering (Step 16).
  snapshotJson Json
  /// Optional Yjs binary state for exact restore.
  yDocState    Bytes?
  kind         VersionKind @default(AUTO)
  createdById  String
  createdAt    DateTime    @default(now())

  page      Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdById], references: [id])

  @@index([pageId, createdAt])
}

model Comment {
  id         String    @id @default(cuid())
  pageId     String
  parentId   String?
  authorId   String
  body       String
  /// Anchor in the editor doc — `{from: number, to: number}` from
  /// ProseMirror, or null for page-level comments.
  anchor     Json?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  page    Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")
  author  User      @relation(fields: [authorId], references: [id])

  @@index([pageId])
  @@index([parentId])
}

model Template {
  id          String   @id @default(cuid())
  /// Null means a system template seeded for every workspace.
  workspaceId String?
  name        String
  description String?
  contentJson Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model PagePermission {
  id     String @id @default(cuid())
  pageId String
  userId String
  role   Role

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pageId, userId])
  @@index([pageId])
  @@index([userId])
}

// ---------- Agile / Epics ----------

enum EpicStatus {
  PLANNED
  IN_PROGRESS
  DONE
}

enum AgileStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Epic {
  id          String     @id @default(cuid())
  workspaceId String
  /// Human-facing label, assigned on create as `EPIC-<n>` (Step 41).
  key         String
  name        String     @default("Untitled epic")
  description String?
  status      EpicStatus @default(PLANNED)
  /// Hex color for the epic chip + board card accent.
  color       String     @default("#5333D8")
  /// Fractional ordering within a board column — see src/lib/pages.ts.
  position    Float      @default(0)
  createdById String
  archivedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("EpicCreatedBy", fields: [createdById], references: [id])
  pages     Page[]

  @@unique([workspaceId, key])
  @@index([workspaceId, status])
}

// ---------- Notifications ----------

model Notification {
  id        String    @id @default(cuid())
  userId    String
  /// NotificationType string — see src/lib/notifications.ts.
  type      String
  /// Denormalized render data (actor name, page title/slug, url, …).
  payload   Json
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model NotificationPreference {
  id           String   @id @default(cuid())
  userId       String   @unique
  /// Per-type email delivery toggles. The in-app inbox always receives.
  emailMention Boolean  @default(true)
  emailReply   Boolean  @default(true)
  emailShare   Boolean  @default(true)
  emailInvite  Boolean  @default(true)
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------- AI usage / quotas ----------

/// One row per workspace per calendar-month, metering managed-tier AI usage
/// (Step 19). BYO-key requests bypass the managed cap and are not metered
/// here. `period` is the UTC "YYYY-MM" bucket; see src/lib/ai-usage.ts.
model AiUsage {
  id           String   @id @default(cuid())
  workspaceId  String
  period       String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  requestCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, period])
  @@index([workspaceId])
}

/// Per-user, per-page AI chat thread (Step 20). One conversation each member
/// keeps about a given PRD; messages persist so the thread survives reloads.
model AiThread {
  id        String   @id @default(cuid())
  pageId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  page     Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  @@unique([pageId, userId])
  @@index([pageId])
}

model AiMessage {
  id        String   @id @default(cuid())
  threadId  String
  /// "user" | "assistant" — maps directly to Anthropic message roles.
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  thread AiThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}
